import { Theme, BookData, ChapterData } from "widgets/theme.slint";

export component BookDetailsView inherits Rectangle {
    in property <BookData> book;
    in property <[ChapterData]> chapters;
    in property <bool> is-loading;
    in property <bool> dark-mode: true;
    in property <string> summary;

    callback go-back();
    callback add-to-library();
    callback remove-from-library();
    callback read-chapter(string);

    background: dark-mode ? Theme.bg-dark : Theme.bg-light;

    VerticalLayout {
        // Top bar
        Rectangle {
            height: 48px;
            background: dark-mode ? Theme.sidebar-dark : Theme.sidebar-light;

            HorizontalLayout {
                padding-left: Theme.spacing-sm;
                padding-right: Theme.spacing-md;

                TouchArea {
                    width: 60px;
                    clicked => { root.go-back(); }

                    Text {
                        text: "← Back";
                        font-size: 14px;
                        color: Theme.accent;
                        vertical-alignment: center;
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                // Library button
                TouchArea {
                    width: 80px;
                    clicked => {
                        if book.in-library {
                            root.remove-from-library();
                        } else {
                            root.add-to-library();
                        }
                    }

                    Rectangle {
                        border-radius: 4px;
                        background: book.in-library ? Theme.success : Theme.accent;

                        Text {
                            text: book.in-library ? "✓ Saved" : "+ Add";
                            font-size: 12px;
                            color: white;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // Content
        Flickable {
            vertical-stretch: 1;
            viewport-height: 800px;  // Will adjust based on content

            VerticalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-md;

                // Book info header
                HorizontalLayout {
                    spacing: Theme.spacing-md;

                    // Cover
                    Rectangle {
                        width: 120px;
                        height: 180px;
                        border-radius: Theme.radius-md;
                        background: Theme.accent.transparentize(0.85);

                        Text {
                            text: "📚";
                            font-size: 48px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Info
                    VerticalLayout {
                        spacing: 6px;

                        Text {
                            text: book.title;
                            font-size: 18px;
                            font-weight: 700;
                            color: dark-mode ? Theme.text-dark : Theme.text-light;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "by " + book.author;
                            font-size: 13px;
                            color: Theme.text-muted-dark;
                        }

                        Rectangle { height: 8px; }

                        HorizontalLayout {
                            spacing: 12px;

                            Text {
                                text: "📖 " + book.chapters-count + " chapters";
                                font-size: 12px;
                                color: Theme.text-muted-dark;
                            }
                        }

                        // Progress bar
                        if book.progress > 0 : VerticalLayout {
                            spacing: 4px;

                            Text {
                                text: Math.round(book.progress * 100) + "% read";
                                font-size: 11px;
                                color: Theme.success;
                            }

                            Rectangle {
                                height: 4px;
                                border-radius: 2px;
                                background: Theme.card-dark;

                                Rectangle {
                                    width: parent.width * book.progress;
                                    height: 100%;
                                    border-radius: 2px;
                                    background: Theme.success;
                                }
                            }
                        }
                    }
                }

                // Summary section
                if summary != "" : VerticalLayout {
                    spacing: 8px;

                    Text {
                        text: "Summary";
                        font-size: 14px;
                        font-weight: 600;
                        color: dark-mode ? Theme.text-dark : Theme.text-light;
                    }

                    Text {
                        text: summary;
                        font-size: 13px;
                        color: Theme.text-muted-dark;
                        wrap: word-wrap;
                    }
                }

                // Chapters section
                VerticalLayout {
                    spacing: 8px;

                    Text {
                        text: "Chapters (" + chapters.length + ")";
                        font-size: 14px;
                        font-weight: 600;
                        color: dark-mode ? Theme.text-dark : Theme.text-light;
                    }

                    // Chapter list
                    for chapter in chapters : Rectangle {
                        height: 48px;
                        border-radius: 8px;
                        background: dark-mode ? Theme.card-dark : Theme.card-light;

                        TouchArea {
                            clicked => { root.read-chapter(chapter.id); }

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;

                                    Text {
                                        text: chapter.title;
                                        font-size: 13px;
                                        color: dark-mode ? Theme.text-dark : Theme.text-light;
                                        overflow: elide;
                                    }

                                    if chapter.date != "" : Text {
                                        text: chapter.date;
                                        font-size: 10px;
                                        color: Theme.text-muted-dark;
                                    }
                                }

                                // Progress indicator
                                if chapter.progress > 0 : Rectangle {
                                    width: 24px;

                                    Text {
                                        text: chapter.progress >= 0.9 ? "✓" : "◐";
                                        font-size: 14px;
                                        color: chapter.progress >= 0.9 ? Theme.success : Theme.accent;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Loading overlay
        if is-loading : Rectangle {
            background: (dark-mode ? Theme.bg-dark : Theme.bg-light).transparentize(0.3);

            VerticalLayout {
                alignment: center;

                Text {
                    text: "⏳";
                    font-size: 32px;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
